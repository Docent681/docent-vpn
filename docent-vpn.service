[Unit]
Description=Docent VPN Flask backend
After=network.target postgresql.service

[Service]
User=admin
Group=admin
WorkingDirectory=/home/admin/docent-vpn/backend
Environment=
ExecStart=/home/admin/docent-vpn/backend/.venv/bin/gunicorn -w 4 -b 127.0.0.1:8000 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
